set style line 12 lc rgb 'blue' lw 1 pt 7   # circle
plot \
TTU_GWU_short u (sc_AtoS*$1):(fac*($5+$7)) w lp ls 7, \
TTU_GWU_far u (sc_AtoS*$1):(fac*($5+$7)) w l dt (30,8,0,15) lw 6 lc 7, \
