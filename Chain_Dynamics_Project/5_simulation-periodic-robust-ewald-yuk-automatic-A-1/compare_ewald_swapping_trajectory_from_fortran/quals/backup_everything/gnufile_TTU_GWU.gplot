abhilash_dir.ahilash_file3 u (sc_AtoS*$2):(sc_AtoS*$3) w l lw 2 lc "blue", \
abhilash_dir.ahilash_file4 u (sc_AtoS*$2):(sc_AtoS*$3) w l lw 2 lc "blue", \
abhilash_dir.ahilash_file5 u (sc_AtoS*$2):(sc_AtoS*$3) w l lw 2 lc "blue", \
"<echo '2.169 0'"   with points ls 12
